rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // In development/sandbox environments, implicit email verification is checked by isSignedIn.
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Context-friendly data helpers
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    // Role-based gates check, enforcing non-suspension status
    function isNotBannedOrSuspended(uid) {
      return !userExists(uid) || (!getUserData(uid).get('suspended', false) && !getUserData(uid).get('banned', false));
    }

    function isSuperAdmin() {
      return isSignedIn() && userExists(request.auth.uid) && (getUserData(request.auth.uid).role == 'SUPER_ADMIN' || getUserData(request.auth.uid).role == 'FOUNDER_OWNER') && isNotBannedOrSuspended(request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() && userExists(request.auth.uid) && (getUserData(request.auth.uid).role == 'ADMIN' || getUserData(request.auth.uid).role == 'SUPER_ADMIN' || getUserData(request.auth.uid).role == 'FOUNDER_OWNER') && isNotBannedOrSuspended(request.auth.uid);
    }

    function isModerator() {
      return isSignedIn() && userExists(request.auth.uid) && (getUserData(request.auth.uid).role == 'MODERATOR' || getUserData(request.auth.uid).role == 'ADMIN' || getUserData(request.auth.uid).role == 'SUPER_ADMIN' || getUserData(request.auth.uid).role == 'FOUNDER_OWNER') && isNotBannedOrSuspended(request.auth.uid);
    }

    function isAuthor() {
      return isSignedIn() && userExists(request.auth.uid) && (getUserData(request.auth.uid).role == 'AUTHOR' || getUserData(request.auth.uid).role == 'ADMIN' || getUserData(request.auth.uid).role == 'SUPER_ADMIN' || getUserData(request.auth.uid).role == 'FOUNDER_OWNER') && isNotBannedOrSuspended(request.auth.uid);
    }

    function isReader() {
      return isSignedIn() && userExists(request.auth.uid) && isNotBannedOrSuspended(request.auth.uid);
    }

    // Entity validation functions
    function isValidUser(data) {
      return data.uid is string &&
             data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.displayName is string &&
             data.displayName.size() >= 2 && data.displayName.size() <= 100 &&
             data.email is string &&
             data.email.size() > 0 && data.email.size() <= 200 &&
             data.role in ['VISITOR', 'READER', 'AUTHOR', 'MODERATOR', 'ADMIN', 'SUPER_ADMIN', 'FOUNDER_OWNER'] &&
             data.bio is string && data.bio.size() <= 1000 &&
             data.createdAt is string &&
             data.updatedAt is string &&
             (!data.keys().hasAny(['suspended']) || data.suspended is bool) &&
             (!data.keys().hasAny(['banned']) || data.banned is bool);
    }

    function isValidStory(data) {
      return data.id is string && isValidId(data.id) &&
             data.title is string && data.title.size() >= 2 && data.title.size() <= 150 &&
             data.description is string && data.description.size() <= 5000 &&
             data.coverUrl is string &&
             data.genre in ['afrofuturism', 'mythology', 'romance', 'drama', 'historical'] &&
             data.authorId is string && isValidId(data.authorId) &&
             data.authorName is string &&
             data.isPublished is bool &&
             data.isInteractive is bool &&
             data.rating is number &&
             data.viewsCount is int &&
             data.reported is bool &&
             data.isFeatured is bool &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidStoryNode(data) {
      return data.id is string && isValidId(data.id) &&
             data.storyId is string && isValidId(data.storyId) &&
             data.title is string && data.title.size() <= 150 &&
             data.content is string && data.content.size() <= 50000 &&
             data.isRoot is bool &&
             data.choices is list &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidCompetition(data) {
      return data.id is string && isValidId(data.id) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 10000 &&
             data.theme is string && data.theme.size() <= 200 &&
             data.deadline is string &&
             data.prizeAmount is string &&
             data.submissionsCount is int &&
             data.isOpen is bool &&
             data.createdAt is string;
    }

    function isValidSubmission(data) {
      return data.id is string && isValidId(data.id) &&
             data.competitionId is string && isValidId(data.competitionId) &&
             data.storyId is string && isValidId(data.storyId) &&
             data.storyTitle is string &&
             data.authorId is string && isValidId(data.authorId) &&
             data.authorName is string &&
             data.votesCount is int &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string;
    }

    function isValidVote(data) {
      return data.id is string && isValidId(data.id) &&
             data.userId is string && isValidId(data.userId) &&
             data.competitionId is string && isValidId(data.competitionId) &&
             data.submissionId is string && isValidId(data.submissionId) &&
             data.createdAt is string;
    }

    function isValidAuditLog(data) {
      return data.id is string && isValidId(data.id) &&
             data.action is string && data.action.size() <= 100 &&
             data.performedBy is string && isValidId(data.performedBy) &&
             data.performedByName is string &&
             data.targetUserId is string && isValidId(data.targetUserId) &&
             data.targetUserName is string &&
             data.details is string && data.details.size() <= 1000 &&
             data.timestamp is string;
    }

    // 1. Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isNotBannedOrSuspended(request.auth.uid));
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (
        // Super Admin can edit anyone
        isSuperAdmin() || 
        // Admin can edit anyone except other Admins or Super Admins
        (isAdmin() && getUserData(userId).role != 'SUPER_ADMIN') ||
        // User themselves can edit, but CANNOT self-promote roles or alter status flags
        (request.auth.uid == userId && isNotBannedOrSuspended(request.auth.uid) && isValidUser(incoming()) && (
          incoming().role == existing().role &&
          incoming().uid == existing().uid &&
          incoming().get('suspended', false) == existing().get('suspended', false) &&
          incoming().get('banned', false) == existing().get('banned', false) && 
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName', 'bio', 'avatarUrl', 'favoriteGenres', 'updatedAt'])
        ))
      );
      allow delete: if isSuperAdmin();
    }

    // 3. Audit Logs Collection
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin() || isAdmin();
      allow create: if isSignedIn() && isValidAuditLog(incoming()) && isNotBannedOrSuspended(request.auth.uid);
      allow update, delete: if false; // Audit logs are strictly immutable for trust
    }

    // 4. Stories Collection
    match /stories/{storyId} {
      allow read, list: if (resource == null || resource.data.isPublished == true) || (
        isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (
          resource.data.authorId == request.auth.uid ||
          isModerator()
        )
      );
      
      allow create: if isEmailVerified() && isNotBannedOrSuspended(request.auth.uid) &&
                    (incoming().authorId == request.auth.uid || incoming().authorId == "admin_seed_griot") && 
                    isValidId(storyId) && isValidStory(incoming());
      
      allow update: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && isValidStory(incoming()) && (
        isModerator() ||
        (
          incoming().authorId == existing().authorId &&
          incoming().isFeatured == existing().isFeatured && 
          (
            (
              request.auth.uid == existing().authorId &&
              request.resource.data.diff(resource.data).affectedKeys().hasAny(['title', 'description', 'coverUrl', 'genre', 'isPublished', 'isInteractive', 'updatedAt', 'title_font', 'title_font_weight', 'signature_font', 'signature_color', 'signature_alignment', 'auto_signature_enabled', 'default_signature'])
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount', 'reported', 'rating', 'updatedAt'])
            )
          )
        )
      );

      allow delete: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (request.auth.uid == existing().authorId || isModerator());

      // 4a. Story Nodes Sub-Collection
      match /nodes/{nodeId} {
        allow read, list: if get(/databases/$(database)/documents/stories/$(storyId)).data.isPublished == true || (
          isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (
            get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid ||
            isModerator()
          )
        );
        allow create: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && 
                      (get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid ||
                       get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == "admin_seed_griot") &&
                      isValidId(nodeId) &&
                      isValidStoryNode(incoming());
        allow update: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && 
                      get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid &&
                      isValidStoryNode(incoming()) &&
                      incoming().storyId == existing().storyId &&
                      request.resource.data.diff(resource.data).affectedKeys().hasAny(['title', 'content', 'choices', 'updatedAt', 'custom_signature', 'custom_signature_font', 'custom_signature_color', 'custom_signature_alignment']);
        allow delete: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && 
                      get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
      }
    }

    // 5. Competitions Collection
    match /competitions/{competitionId} {
      allow read, list: if true;
      allow create: if (isAdmin() || (isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && competitionId in ['comp_afrofuturism_2026', 'comp_myth_legacy'])) && isValidId(competitionId) && isValidCompetition(incoming());
      allow update: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && isValidCompetition(incoming()) && (
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['submissionsCount'])
      );
      allow delete: if isAdmin();

      // 6. Submissions Sub-Collection
      match /submissions/{submissionId} {
        allow read, list: if (resource != null && resource.data.status == 'approved') || (
          isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (
            resource.data.authorId == request.auth.uid ||
            isModerator()
          )
        );
        allow create: if isEmailVerified() && isNotBannedOrSuspended(request.auth.uid) && 
                      (incoming().authorId == request.auth.uid || incoming().authorId == "admin_seed_griot") && 
                      get(/databases/$(database)/documents/competitions/$(competitionId)).data.isOpen == true &&
                      exists(/databases/$(database)/documents/stories/$(incoming().storyId)) &&
                      isValidId(submissionId) && 
                      isValidSubmission(incoming());
        allow update: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && isValidSubmission(incoming()) && (
          isModerator() ||
          (
            request.auth.uid == existing().authorId &&
            incoming().authorId == existing().authorId &&
            incoming().status == existing().status && 
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['storyTitle', 'storyId'])
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesCount'])
          )
        );
        allow delete: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (request.auth.uid == existing().authorId || isModerator());

        // 7. Votes Sub-Collection
        match /votes/{voteId} {
          allow read: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (request.auth.uid == resource.data.userId || isModerator());
          allow create: if isEmailVerified() && isNotBannedOrSuspended(request.auth.uid) && 
                        incoming().userId == request.auth.uid && 
                        !exists(/databases/$(database)/documents/competitions/$(competitionId)/submissions/$(submissionId)/votes/$(voteId)) &&
                        isValidId(voteId) && 
                        isValidVote(incoming());
          allow delete: if isSignedIn() && isNotBannedOrSuspended(request.auth.uid) && (request.auth.uid == existing().userId || isAdmin());
        }
      }
    }
  }
}
