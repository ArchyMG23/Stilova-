# =================================================================
# STILOVA BACKEND - PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# =================================================================

# 1. DATABASE CONFIGURATION (POSTGRESQL)
# Standard format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://stilova_admin:stilova_secure_pwd_2026@localhost:5432/stilova_db?schema=public"

# 2. CACHING & QUEUE ENGINE (REDIS)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="redis_secure_password"
REDIS_TLS="false"

# 3. GOOGLE COGNITIVE SERVICE (GEMINI API KEY)
# Obtain this key from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=""

# 4. JWT SECURITY CONSTANTS
# Generate strong, random symmetric cryptographic keys (e.g., openssl rand -base64 32)
JWT_ACCESS_SECRET="generate_a_very_long_random_string_for_access_token_security"
JWT_REFRESH_SECRET="generate_another_long_random_string_for_rotation_refresh_token_security"

# 5. SERVER RUNTIME SETTINGS
PORT=3000
NODE_ENV="development"
